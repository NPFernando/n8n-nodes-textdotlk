{
	"name": "n8n-nodes-textdotlk",
	"version": "0.1.2",
	"description": "Custom N8N nodes for textdot.lk service",
	"license": "MIT",
	"homepage": "https://github.com/NPFernando/n8n-nodes-textdotlk#readme",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Naveen Fernando"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/NPFernando/n8n-nodes-textdotlk.git"
	},
	"bugs": {
		"url": "https://github.com/NPFernando/n8n-nodes-textdotlk/issues"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease",
		"validate:package": "npm run lint && npm run build && npm run audit:prod && npx tsc --noEmit && npm pack --dry-run",
		"audit:prod": "npm audit --omit=dev --audit-level=critical"
	},
	"files": [
		"dist",
		"!dist/**/*.tsbuildinfo",
		"!dist/*.tsbuildinfo"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/TextDotLkApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/TextDotLk/TextDotLk.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "0.34.0",
		"eslint": "9.29.0",
		"prettier": "3.8.3",
		"release-it": "^20.2.0",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"engines": {
		"node": ">=20.19 <23",
		"npm": ">=10"
	}
}
